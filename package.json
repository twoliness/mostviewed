		"next": "^15.5.15",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"recharts": "^3.9.0",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250918.0",
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@types/react": "19.1.13",
		"eslint": "^9",
		"eslint-config-next": "15.4.6",
		"tailwindcss": "^4",
		"typescript": "5.9.2",
		"wrangler": "^4.83.0"
	}
